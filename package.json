{
	"name": "plebis-online-website",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"postbuild": "bunx svelte-sitemap -d https://plebis.online -i '404.html' -c weekly -r",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"machine-translate": "inlang machine translate --project project.inlang"
	},
	"devDependencies": {
		"@inlang/cli": "^3.1.6",
		"@inlang/paraglide-js": "2.13.2",
		"@skeletonlabs/skeleton": "^4.12.1",
		"@skeletonlabs/skeleton-svelte": "^4.12.1",
		"@sveltejs/adapter-static": "3.0.10",
		"@sveltejs/kit": "2.53.4",
		"@sveltejs/vite-plugin-svelte": "6.2.4",
		"@tailwindcss/forms": "0.5.11",
		"@tailwindcss/typography": "0.5.19",
		"@tailwindcss/vite": "4.2.1",
		"@types/luxon": "3.7.1",
		"lucide-svelte": "0.577.0",
		"luxon": "3.7.2",
		"prettier": "3.8.1",
		"prettier-plugin-svelte": "3.5.1",
		"prettier-plugin-tailwindcss": "0.7.2",
		"svelte": "5.53.7",
		"svelte-check": "4.4.4",
		"svelte-sitemap": "^3.0.0",
		"tailwindcss": "4.2.1",
		"typescript": "5.9.3",
		"vite": "7.3.1"
	}
}
